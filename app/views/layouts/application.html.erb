<!DOCTYPE html>
<html>
  <head>
    <title>FruitVeg - Price Tracker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <style>
      /* Sidebar mobile */
      #mobile-sidebar { display: none; }
      #mobile-sidebar-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 40;
      }
      #mobile-sidebar-content {
        position: fixed; top: 0; right: 0; width: 70%; max-width: 300px;
        height: auto; max-height: 90vh; background: white; z-index: 50;
        overflow-y: auto; box-shadow: -2px 0 10px rgba(0,0,0,0.1);
      }
      /* Contenu principal */
      .main-content {
        margin-left: 0; /* Par défaut pour mobile */
      }
      @media (min-width: 768px) {
        .main-content {
          margin-left: 16rem; /* 64px (w-64) pour la navbar desktop */
        }
      }
    </style>
  </head>

  <body class="bg-gray-50">
    <!-- En-tête mobile -->
    <div class="md:hidden bg-white p-4 shadow-md flex justify-between items-center">
      <div class="flex items-center">
        <div class="bg-green-100 p-2 rounded-lg mr-2">
          <i class="fas fa-apple-alt text-green-600"></i>
        </div>
        <h1 class="text-lg font-semibold">FruitVeg</h1>
      </div>
      <button id="menu-toggle" class="p-2 text-gray-600" style="font-size: 24px;">
        <i class="fas fa-bars"></i>
      </button>
    </div>

    <!-- Sidebar mobile -->
    <div id="mobile-sidebar">
      <div id="mobile-sidebar-backdrop" onclick="closeMobileSidebar()"></div>
      <div id="mobile-sidebar-content">
        <div class="p-4">
          <div class="flex justify-between items-center mb-6">
            <div class="flex items-center">
              <div class="bg-green-100 p-2 rounded-lg mr-2">
                <i class="fas fa-apple-alt text-green-600"></i>
              </div>
              <h1 class="text-lg font-semibold">FruitVeg</h1>
            </div>
            <button onclick="closeMobileSidebar()" class="text-gray-600">
              <i class="fas fa-times"></i>
            </button>
          </div>
          <nav class="flex flex-col space-y-2">
            <%= link_to products_path, class: "flex items-center p-2 rounded-lg #{'bg-green-100' if current_page?(products_path)}" do %>
              <i class="fas fa-apple-alt mr-2 #{'text-green-600' if current_page?(products_path)}"></i>
              <span class="#{'text-green-600 font-medium' if current_page?(products_path)}">Sélection Produits</span>
            <% end %>
            <!-- Autres liens... -->
          </nav>
          <div class="mt-4 p-2 bg-gray-100 rounded-lg">
            <p class="text-sm font-medium">Matthieu BURGOT</p>
            <p class="text-xs text-gray-500">Responsable Prix</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar DESKTOP (toujours visible) -->
    <div class="hidden md:block fixed w-64 bg-white h-full p-4 shadow-md">
      <div class="flex items-center mb-8">
        <div class="bg-green-100 p-2 rounded-lg mr-2">
          <i class="fas fa-apple-alt text-green-600"></i>
        </div>
        <div>
          <h1 class="text-lg font-semibold">FruitVeg</h1>
          <p class="text-sm text-gray-500">Price Tracker</p>
        </div>
      </div>
      <nav class="flex-1">
        <%= link_to products_path, class: "flex items-center p-2 mb-2 rounded-lg #{'bg-green-100' if current_page?(products_path)}" do %>
          <i class="fas fa-apple-alt mr-2 #{'text-green-600' if current_page?(products_path)}"></i>
          <span class="#{'text-green-600 font-medium' if current_page?(products_path)}">Sélection Produits</span>
        <% end %>
        <!-- Autres liens... -->
      </nav>
                <div class="mt-4 p-2 bg-gray-100 rounded-lg">
            <p class="text-xl font-medium">Matthieu BURGOT</p>
            <p class="text-xs text-gray-500">Responsable Prix</p>
          </div>
    </div>

    <!-- Contenu principal avec marge gauche pour desktop -->
    <div class="main-content p-4 md:p-8">
      <%= yield %>
    </div>

    <!-- Script pour le menu mobile -->
    <script>
      function closeMobileSidebar() {
        document.getElementById('mobile-sidebar').style.display = 'none';
      }
      document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('menu-toggle').addEventListener('click', function() {
          document.getElementById('mobile-sidebar').style.display = 'block';
        });
      });
    </script>
  </body>
</html>









