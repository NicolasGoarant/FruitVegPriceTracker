<div class="flex h-screen bg-gray-50">
  <!-- Sidebar -->
  <div class="w-64 bg-white shadow-md p-4 flex flex-col">
    <div class="flex items-center mb-8">
      <div class="bg-green-100 p-2 rounded-lg mr-2">
        <i class="fas fa-apple-alt text-green-600"></i>
      </div>
      <div>
        <h1 class="text-lg font-semibold">FruitVeg</h1>
        <p class="text-sm text-gray-500">Price Tracker</p>
      </div>
    </div>
    <nav class="flex-1">
      <%= link_to products_path, class: "flex items-center p-2 mb-2 hover:bg-gray-100 rounded-lg" do %>
        <i class="fas fa-apple-alt mr-2"></i> Sélection Produits
      <% end %>
    </nav>
  </div>

  <!-- Main Content -->
  <div class="flex-1 p-8 overflow-auto">
    <div class="flex items-center mb-6">
      <%= link_to product_path(@product), class="flex items-center text-gray-600 hover:text-gray-800" do %>
        <i class="fas fa-arrow-left mr-2"></i> Retour
      <% end>
    </div>

    <div class="max-w-2xl mx-auto bg-white p-6 rounded-lg shadow-sm border border-gray-200">
      <h1 class="text-xl font-bold mb-6">Nouveau Prix pour <%= @product.name %></h1>

      <%= form_with(model: [@product, @price], local: true, class: "space-y-6") do |form| %>
        <div>
          <%= form.label :value, "Prix (€/kg)", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <%= form.number_field :value, step: 0.01, class: "focus:ring-green-500 focus:border-green-500 block w-full pl-3 pr-12 sm:text-sm border-gray-300 rounded-md", placeholder: "Ex: 2,50" %>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
              <span class="text-gray-500 sm:text-sm">€</span>
            </div>
          </div>
        </div>

        <div>
          <%= form.label :date, "Date", class: "block text-sm font-medium text-gray-700" %>
          <%= form.datetime_local_field :date, value: DateTime.now, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
        </div>

        <div>
          <%= form.label :market_type, "Type de marché", class: "block text-sm font-medium text-gray-700" %>
          <%= form.select :market_type, [['Gros', 'gros'], ['Distributeur', 'distributeur']], {}, class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm rounded-md" %>
        </div>

        <div class="flex justify-end space-x-3">
          <%= link_to "Annuler", product_path(@product), class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
          <%= form.submit "Enregistrer", class: "bg-green-600 hover:bg-green-700 text-white py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

