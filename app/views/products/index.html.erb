<div class="p-4 md:p-8">
  <div class="flex flex-col mb-6">
    <h1 class="text-2xl font-bold mb-2">Suivi des Prix</h1>
    <p class="text-gray-500">Fruits et Légumes</p>
    <p class="text-center text-gray-500 mt-4 text-sm md:text-base">
      Cliquez sur un produit pour voir son historique et saisir un nouveau prix
    </p>
  </div>

  <!-- Fruits Section -->
  <div class="mb-8">
    <div class="flex items-center mb-4">
      <h2 class="text-xl font-semibold mr-2">Fruits</h2>
      <span class="bg-orange-100 text-orange-500 text-xs px-2 py-1 rounded-full">
        <%= @products.select { |p| p.category == "Fruits" }.count %> produits
      </span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      <% @products.select { |p| p.category == "Fruits" }.each do |product| %>
        <%= link_to product_path(product), class: "bg-white p-4 rounded-lg shadow hover:shadow-md transition" do %>
          <div class="flex flex-col items-center">
            <%= image_tag product.image_url, alt: product.name, class: "w-20 h-20 object-cover mb-2" %>
            <p class="font-medium text-center"><%= product.name %></p>
            <p class="text-sm text-gray-500">Prix par kg</p>
          </div>
        <% end %>
      <% end %>
    </div>

  <!-- Légumes Section -->
  <div>
    <div class="flex items-center mb-4">
      <h2 class="text-xl font-semibold mr-2">Légumes</h2>
      <span class="bg-orange-100 text-orange-500 text-xs px-2 py-1 rounded-full">
        <%= @products.select { |p| p.category == "Légumes" }.count %> produits
      </span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      <% @products.select { |p| p.category == "Légumes" }.each do |product| %>
        <%= link_to product_path(product), class: "bg-white p-4 rounded-lg shadow hover:shadow-md transition" do %>
          <div class="flex flex-col items-center">
            <%= image_tag product.image_url, alt: product.name, class: "w-20 h-20 object-cover mb-2" %>
            <p class="font-medium text-center"><%= product.name %></p>
            <p class="text-sm text-gray-500">Prix par kg</p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

